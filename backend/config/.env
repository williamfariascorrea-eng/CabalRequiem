# Database Configuration
# Tipos suportados: sqlsrv (SQL Server) ou mysql
DB_TYPE=sqlsrv

# SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=CabalOnline
DB_USER=sa
DB_PASS=your_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_EXPIRE=3600

# Application Settings
APP_ENV=development
APP_DEBUG=true